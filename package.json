  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "1.7.9",
    "express": "4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "22.10.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
