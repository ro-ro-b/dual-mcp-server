{
  "name": "dual-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for DUAL tokenization platform — AI-native integration with wallets, templates, objects, actions, and blockchain infrastructure",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dual-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
