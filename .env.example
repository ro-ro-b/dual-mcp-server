# DUAL MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your .env file to version control.

# ── Authentication (pick one) ─────────────────────────────────────────────────

# Option 1: API Key (recommended for server-to-server integrations)
# DUAL_API_KEY=your-api-key-here

# Option 2: JWT Token (from dual_login tool or existing session)
# DUAL_ACCESS_TOKEN=your-jwt-access-token
# DUAL_REFRESH_TOKEN=your-jwt-refresh-token  # optional, enables auto-refresh

# ── DUAL API ──────────────────────────────────────────────────────────────────

# API base URL (default shown — only change for self-hosted or staging)
# DUAL_API_URL=https://api.blockv-labs.io/v3

# ── Transport ─────────────────────────────────────────────────────────────────

# Transport mode: "stdio" (default, for Claude/Cursor) or "http" (remote)
# TRANSPORT=stdio

# HTTP mode options (only used when TRANSPORT=http)
# PORT=3100
# HOST=127.0.0.1                        # bind address (127.0.0.1 = localhost only)
# MCP_SERVER_API_KEY=change-me-strong-random-secret   # REQUIRED for HTTP mode
# CORS_ORIGIN=https://app.example.com   # comma-separated allowed browser origins
# RATE_LIMIT_MAX=100                    # max requests per IP per minute

# ── AI Service Dependencies ───────────────────────────────────────────────────
# Required only if you use intelligence / governance / creative tools.
# These are separate DUAL AI microservices running alongside this server.

# INTELLIGENCE_URL=http://localhost:3201
# GOVERNANCE_URL=http://localhost:3202
# CREATIVE_URL=http://localhost:3203
